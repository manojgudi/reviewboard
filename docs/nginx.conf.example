# Nginx configuration for Review Board
# Place this in /etc/nginx/sites-available/reviewboard

upstream reviewboard {
    server 127.0.0.1:8090;
    keepalive 32;
}

server {
    listen 80;
    server_name reviewboard.example.com;
    
    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name reviewboard.example.com;
    
    # SSL Configuration
    ssl_certificate /etc/letsencrypt/live/reviewboard.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/reviewboard.example.com/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/reviewboard.example.com/chain.pem;
    
    # SSL Security Settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_stapling on;
    ssl_stapling_verify on;
    
    # HSTS (uncomment after verifying HTTPS works)
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    
    # Logging
    access_log /var/log/nginx/reviewboard_access.log;
    error_log /var/log/nginx/reviewboard_error.log;
    
    # Max upload size (must match MAX_CONTENT_LENGTH in Flask)
    client_max_body_size 20M;
    
    # Timeouts
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    
    location / {
        proxy_pass http://reviewboard;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # WebSocket support (if needed)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # Prevent buffering of large responses
        proxy_buffering off;
    }
    
    # Static files (optional - serve directly instead of through Flask)
    # location /static/ {
    #     alias /path/to/reviewboard/static/;
    #     expires 30d;
    #     add_header Cache-Control "public, immutable";
    # }
    
    # Health check endpoint
    location /health {
        proxy_pass http://reviewboard;
        access_log off;
    }
}
